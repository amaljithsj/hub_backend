{
  "id": "cixio.hooks.eventStreaming",
  "name": "Kafka Event Publisher Sync",
  "event": "PostToolUse",
  "action": {
    "type": "shellExecution",
    "command": "python3",
    "args": [
      "scripts/sync_kafka_events.py"
    ],
    "options": {
      "env": {
        "TARGET_FILE": "${activeEditorFile}"
      }
    }
  },
  "timeout": 15000
}