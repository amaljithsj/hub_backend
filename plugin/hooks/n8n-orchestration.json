{
  "id": "cixio.hooks.n8nOrchestration",
  "name": "n8n Orchestration Sync",
  "event": "PostToolUse",
  "action": {
    "type": "shellExecution",
    "command": "python3",
    "args": [
      "scripts/sync_n8n_webhooks.py"
    ],
    "options": {
      "env": {
        "TARGET_FILE": "${activeEditorFile}"
      }
    }
  },
  "timeout": 15000
}